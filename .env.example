# ----------------------------------------------------
# OpenCrowd - Environment Variables
# Copy this file to .env before running docker compose
# ----------------------------------------------------

# URL where the API will be accessible from the internet
# (Used to compile the React frontend)
VITE_API_URL=https://api.yourdomain.com

# Database Credentials
POSTGRES_USER=protest_user
POSTGRES_PASSWORD=protest_secure_password
POSTGRES_DB=protest_db

# Backend Configuration
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public
REDIS_URL=redis://redis:6379
PORT=3001
