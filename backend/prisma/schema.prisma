generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Submission {
  id        String   @id @default(uuid())
  lat       Float
  lng       Float
  accuracy  Float
  timestamp DateTime
  sessionId String
  deviceId  String   @unique

  @@index([sessionId])
  @@index([timestamp])
}
